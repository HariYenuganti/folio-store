# The app runs with mock data when these are empty.
# Fill them in to enable the real Supabase + Stripe backend.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Set to "true" to show "Continue with Google" on the auth pages.
# Requires enabling the Google provider in Supabase Auth → Providers.
NEXT_PUBLIC_OAUTH_GOOGLE=

# Postgres connection string (Supabase or local). Used by Drizzle.
DATABASE_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Base URL for callbacks (Stripe redirect URLs). Defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
